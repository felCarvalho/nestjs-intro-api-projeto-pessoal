{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "migrations/**/.*.json", "outDir": "dist/src", "watchAssets": true },
      { "include": "migrations/**/*.json", "outDir": "dist/src", "watchAssets": true },
      { "include": "seeders/**/*", "outDir": "dist/src", "watchAssets": true }
    ],
    "plugins": ["@nestjs/swagger"]
  }
}
